# Context Management — Environment Variables
# Copy to .env and fill in values for production use.

# Model context window size — match to the model you're calling.
# GPT-4o: 128000, Claude Sonnet: 200000, GPT-4o-mini: 128000
CONTEXT_MAX_TOKENS=128000

# Tokens to reserve for the model's response.
# Set to p99 of your observed output lengths + 20% margin.
CONTEXT_RESERVE_FOR_OUTPUT=4000

# Trim strategy: sliding-window | priority | summarize
CONTEXT_STRATEGY=sliding-window

# For 'summarize' strategy: how many recent messages to keep verbatim.
CONTEXT_KEEP_RECENT=10
